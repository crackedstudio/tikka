# Prevent pnpm 10+ from enforcing a workspace root when invoked
# from inside any of the per-package directories (client/, sdk/,
# backend/, indexer/, oracle/). The repo intentionally keeps each
# package's installation independent with its own pnpm-lock.yaml;
# CI runs `pnpm install --frozen-lockfile` per package, so we must
# NOT treat the root as a workspace.
ignore-workspace=true
