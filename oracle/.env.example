# Horizon Circuit Breaker
# Number of consecutive Horizon SSE failures before the circuit opens
ORACLE_CB_FAILURE_THRESHOLD=5

# Milliseconds the circuit stays open before allowing a probe attempt
ORACLE_CB_RESET_TIMEOUT_MS=60000

# Priority Queue Tier Thresholds
# Minimum prize amount (in XLM) for a draw request to be classified as HIGH priority (Bull priority 1)
ORACLE_HIGH_VALUE_THRESHOLD_XLM=10000

# Minimum prize amount (in XLM) for a draw request to be classified as MEDIUM priority (Bull priority 5)
# Must be less than ORACLE_HIGH_VALUE_THRESHOLD_XLM; falls back to defaults if not
ORACLE_MED_VALUE_THRESHOLD_XLM=1000
