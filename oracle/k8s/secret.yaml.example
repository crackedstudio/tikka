# Do NOT commit real values. Use a secrets manager (e.g. Sealed Secrets, ESO) in production.
# Generate base64 values with: echo -n "your-value" | base64
#
# tikka-oracle-age-key is mounted as a file at /run/secrets/age.key
# tikka-oracle-secrets provides env vars to the container
apiVersion: v1
kind: Secret
metadata:
  name: tikka-oracle-secrets
  namespace: tikka
  labels:
    app: tikka-oracle
type: Opaque
data:
  STELLAR_SECRET_KEY: <base64-encoded-stellar-secret-key>
  TIKKA_CONTRACT_ID: <base64-encoded-contract-id>
  DATABASE_URL: <base64-encoded-database-url>
---
apiVersion: v1
kind: Secret
metadata:
  name: tikka-oracle-age-key
  namespace: tikka
  labels:
    app: tikka-oracle
type: Opaque
data:
  age.key: <base64-encoded-age-private-key>
