{
  "name": "@tikka/sdk",
  "version": "0.1.0",
  "description": "NestJS SDK for Tikka Soroban contract interaction",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "test": "jest",
    "examples:check": "tsc --project examples/tsconfig.json",
    "example:quickstart": "ts-node examples/quickstart.ts",
    "example:create-raffle": "ts-node examples/create-raffle.ts",
    "example:buy-tickets": "ts-node examples/buy-tickets.ts",
    "example:listen-events": "ts-node examples/listen-events.ts",
    "example:offline-signing": "ts-node examples/offline-signing.ts",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch"
  },
  "dependencies": {
    "@albedo-link/intent": "^0.13.0",
    "@lobstrco/signer-extension-api": "^2.0.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@stellar/freighter-api": "^3.1.0",
    "@stellar/stellar-sdk": "^14.5.0",
    "bignumber.js": "^9.3.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/testing": "^10.4.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "4.11",
    "typescript": "^5.6.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "testEnvironment": "node"
  }
}
