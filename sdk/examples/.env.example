# Tikka SDK Examples Environment Template
# Copy this file to .env and fill in values for the examples you want to run
#
# Network Configuration (optional, defaults to testnet)
TIKKA_NETWORK=testnet
# Options: testnet, mainnet, standalone, custom (if using custom RPC endpoint)

# Account Configuration
TIKKA_PUBLIC_KEY=GBIQ4VH3TRO5A72SCCSHV5QZJVUHMFAZVD5K4PIWL3RBQFKBDLPHJ36
# Your Stellar account's public key (G... address)

# ── Raffle Parameters ────────────────────────────────────────────────────
# Used in: create-raffle.ts, estimate-fee.ts

TIKKA_RAFFLE_ID=1
# ID of an existing raffle to interact with (for buy-tickets, listen-events)

TIKKA_TICKET_PRICE=1
# Price per ticket (default: 1 XLM)

TIKKA_MAX_TICKETS=50
# Maximum number of tickets for a raffle (default: 50)

TIKKA_DURATION_HOURS=24
# How many hours until raffle closes (default: 24)

TIKKA_QUANTITY=1
# Number of tickets to buy or quantity to estimate (default: 1)

# ── Asset Configuration ──────────────────────────────────────────────────
# Used in: create-raffle.ts
# Leave empty for XLM, provide both for custom assets

TIKKA_ASSET_CODE=XLM
# Asset code (XLM for native, or any issued asset code like USDC)

TIKKA_ASSET_ISSUER=
# Issuer public key (only needed for non-native assets)
# Example for USDC: GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN

# ── Metadata Configuration ───────────────────────────────────────────────
# Used in: create-raffle.ts

TIKKA_METADATA_CID=
# IPFS CID for raffle metadata (optional, leave empty if none)

# ── Event Listening Configuration ────────────────────────────────────────
# Used in: listen-events.ts

TIKKA_POLL_MS=5000
# Polling interval in milliseconds (default: 5000ms = 5 seconds)

TIKKA_CONTRACT_ID=
# Contract ID (optional, uses default for TIKKA_NETWORK if empty)

# ── Offline Signing Configuration ────────────────────────────────────────
# Used in: offline-signing.ts

TIKKA_SIGNED_XDR=
# Pre-signed XDR for submission (used when resuming a previously built transaction)
# Leave empty for typical flows

# ── Custom RPC Configuration ─────────────────────────────────────────────
# Advanced: Override default RPC endpoints

TIKKA_RPC_URL=
# Custom Soroban RPC URL (example: https://soroban-rpc.testnet.stellar.org)

TIKKA_HORIZON_URL=
# Custom Horizon URL (example: https://horizon-testnet.stellar.org)
