{
  "name": "tikka",
  "private": true,
  "description": "Tikka monorepo — decentralized raffle platform on Stellar",
  "scripts": {
    "build": "pnpm -r run build",
    "build:client": "pnpm --filter tikka-client run build",
    "build:sdk": "pnpm --filter @tikka/sdk run build",
    "build:backend": "pnpm --filter tikka-backend run build",
    "build:indexer": "pnpm --filter tikka-indexer run build",
    "build:oracle": "pnpm --filter tikka-oracle run build",
    "test": "pnpm -r run test",
    "test:client": "pnpm --filter tikka-client run test",
    "test:sdk": "pnpm --filter @tikka/sdk run test",
    "test:backend": "pnpm --filter tikka-backend run test",
    "test:indexer": "pnpm --filter tikka-indexer run test",
    "test:oracle": "pnpm --filter tikka-oracle run test",
    "lint": "pnpm -r run lint",
    "lint:client": "pnpm --filter tikka-client run lint",
    "lint:sdk": "pnpm --filter @tikka/sdk run lint",
    "lint:backend": "pnpm --filter tikka-backend run lint",
    "lint:indexer": "pnpm --filter tikka-indexer run lint",
    "lint:oracle": "pnpm --filter tikka-oracle run lint",
    "dev:client": "pnpm --filter tikka-client run dev",
    "dev:backend": "pnpm --filter tikka-backend run start:dev",
    "dev:indexer": "pnpm --filter tikka-indexer run start:dev",
    "dev:oracle": "pnpm --filter tikka-oracle run start:dev"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  }
}
