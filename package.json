{
  "name": "tikka",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.4.0",
  "scripts": {
    "install:all": "pnpm install",
    "build": "pnpm -r build",
    "build:client": "pnpm --filter client build",
    "build:sdk": "pnpm --filter sdk build",
    "build:backend": "pnpm --filter backend build",
    "build:indexer": "pnpm --filter indexer build",
    "build:oracle": "pnpm --filter oracle build",
    "test": "pnpm -r test",
    "test:client": "pnpm --filter client test",
    "test:sdk": "pnpm --filter sdk test",
    "test:backend": "pnpm --filter backend test",
    "test:indexer": "pnpm --filter indexer test",
    "test:oracle": "pnpm --filter oracle test",
    "lint": "pnpm -r lint",
    "lint:client": "pnpm --filter client lint",
    "lint:sdk": "pnpm --filter sdk lint",
    "lint:backend": "pnpm --filter backend lint",
    "lint:indexer": "pnpm --filter indexer lint",
    "lint:oracle": "pnpm --filter oracle lint"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/react-router-dom": "^5.3.3"
  },
  "dependencies": {
    "react-router-dom": "^7.13.2"
  }
}
