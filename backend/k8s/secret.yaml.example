# Do NOT commit real values. Use a secrets manager (e.g. Sealed Secrets, ESO) in production.
# Generate base64 values with: echo -n "your-value" | base64
apiVersion: v1
kind: Secret
metadata:
  name: tikka-backend-secrets
  namespace: tikka
  labels:
    app: tikka-backend
type: Opaque
data:
  SUPABASE_URL: <base64-encoded-url>
  SUPABASE_SERVICE_ROLE_KEY: <base64-encoded-service-role-key>
  JWT_SECRET: <base64-encoded-secret>
  ADMIN_TOKEN: <base64-encoded-admin-token>
