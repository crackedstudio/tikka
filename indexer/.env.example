# Database Connection
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tikka
# Optional: comma-separated read-replica URLs for leaderboard / read-heavy queries
# DATABASE_REPLICA_URL=postgres://postgres:postgres@replica1:5432/tikka,postgres://postgres:postgres@replica2:5432/tikka

# Redis Connection (Optional, used for caching)
REDIS_URL=redis://localhost:6379

# Horizon / Soroban RPC configuration
SOROBAN_RPC_URL="https://soroban-testnet.stellar.org"
TIKKA_CONTRACT_ID="C..."

# Max Soroban events processed per DB transaction in the ledger poller (default: 100)
# INDEXER_BATCH_SIZE=100

# Dry-run mode: set to "true" to log DB operations without committing (useful for CI/CD)
# DRY_RUN=false

# Health endpoint: Horizon URL for latest-ledger check (default: https://horizon.stellar.org)
# HORIZON_URL=https://horizon.stellar.org

# Health: lag above this many ledgers is reported as degraded (default: 100)
# LAG_THRESHOLD=100

# Health: lag above this many ledgers triggers critical alerts and notifications (default: 50)
# INDEXER_LAG_ALERT_THRESHOLD_LEDGERS=50
