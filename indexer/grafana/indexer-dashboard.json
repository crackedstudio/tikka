      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [{"expr": "sum by (error_type) (rate(tikka_indexer_errors_total[1m]))", "refId": "A", "legendFormat": "{{error_type}}"}],
      "title": "Error Rate by Type",
