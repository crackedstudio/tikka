      "id": 8,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(tikka_cache_latency_seconds_bucket[5m]))", "refId": "A", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, rate(tikka_cache_latency_seconds_bucket[5m]))", "refId": "B", "legendFormat": "p95"},
        {"expr": "histogram_quantile(0.99, rate(tikka_cache_latency_seconds_bucket[5m]))", "refId": "C", "legendFormat": "p99"}
      ],
      "title": "Cache Latency Percentiles",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
