      "id": 7,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [{"expr": "sum by (operation) (rate(tikka_db_slow_query_total[1m]))", "refId": "A", "legendFormat": "{{operation}}"}],
