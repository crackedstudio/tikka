      "id": 3,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [{"expr": "sum by (event_type) (rate(tikka_indexer_events_failed_total[1m]))", "refId": "A", "legendFormat": "{{event_type}}"}],
      "title": "Event Failures Rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
